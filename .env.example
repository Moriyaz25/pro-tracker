# PostgreSQL is accessed only by Next.js server routes. Never prefix this with NEXT_PUBLIC_.
DATABASE_URL=postgresql://postgres:password@localhost:5432/pro-traacker
DATABASE_SSL=false
# For hosted PostgreSQL, normally set DATABASE_SSL=true.
# Only set this false if your provider explicitly requires it.
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Used once to bootstrap the first admin when the users table has no admin.
ADMIN_EMAIL=admin@hospitalpro.com
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_NAME=Super Admin
